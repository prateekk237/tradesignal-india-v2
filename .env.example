# TradeSignal India v2 — Environment Configuration
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tradesignal
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/tradesignal

# Redis
REDIS_URL=redis://localhost:6379/0

# NVIDIA NIM API (LLaMA 3.3 70B)
NIM_API_KEY=your_nvidia_nim_api_key_here
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama-3.3-70b-instruct

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# App
ENVIRONMENT=development
DEBUG=true
